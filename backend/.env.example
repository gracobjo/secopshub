# SecOps Hub — variables de entorno
# Copiar a backend/.env y ajustar valores

# Flask / JWT (obligatorio en produccion)
SECRET_KEY=cambiar-clave-secreta-minimo-32-caracteres
JWT_SECRET_KEY=cambiar-clave-jwt-minimo-32-caracteres
JWT_ACCESS_TOKEN_EXPIRES=8

# Base de datos
DATABASE_URL=sqlite:///secops_hub.db
# DATABASE_URL=postgresql://secops:password@localhost:5432/secops_hub

# Webhook SIEM
WEBHOOK_API_KEY=secops-webhook-key-dev

# Seed demo (desactivar en produccion)
ENABLE_SEED=true
FLASK_ENV=development
BEHIND_PROXY=false
PORT=5000

# --- Fase 2: Threat Intel (opcional) ---
# Sin claves = enriquecimiento simulado automatico
ABUSEIPDB_API_KEY=
VIRUSTOTAL_API_KEY=

# --- Fase 3: Playbooks / respuesta automatizada ---
EDR_TYPE=                    # defender | crowdstrike
EDR_API_TOKEN=
EDR_API_URL=

FIREWALL_TYPE=                 # palo_alto | pfsense
FIREWALL_API_URL=
FIREWALL_API_KEY=

AZURE_AD_TENANT_ID=            # Revocacion usuario via Graph API

# Webhook interno de automatizacion (SOAR, Ansible, n8n)
PLAYBOOK_CALLBACK_URL=
