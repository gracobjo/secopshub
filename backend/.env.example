# SecOps Hub — variables de entorno
# Copiar a backend/.env y ajustar valores

# Flask / JWT
# En producción (FLASK_ENV=production) SECRET_KEY, JWT_SECRET_KEY y
# WEBHOOK_API_KEY son obligatorias (≥ 32 caracteres, no valores de demo).
SECRET_KEY=cambiar-clave-secreta-minimo-32-caracteres
JWT_SECRET_KEY=cambiar-clave-jwt-minimo-32-caracteres
JWT_ACCESS_TOKEN_EXPIRES=8

# Base de datos
# Desarrollo: SQLite (por defecto)
DATABASE_URL=sqlite:///secops_hub.db
# Producción (recomendado):
# DATABASE_URL=postgresql+psycopg://secops:password@localhost:5432/secops_hub

# CORS — orígenes permitidos del frontend (separados por coma). No usar *.
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Webhook SIEM
WEBHOOK_API_KEY=secops-webhook-key-dev

# Seed demo (desactivar en producción)
ENABLE_SEED=true
FLASK_ENV=development
BEHIND_PROXY=false
PORT=5000

# Bootstrap del primer admin cuando ENABLE_SEED=false y la BD está vacía.
# Alternativa: python scripts/create_admin.py
# BOOTSTRAP_ADMIN_USERNAME=admin
# BOOTSTRAP_ADMIN_EMAIL=admin@secops.local
# BOOTSTRAP_ADMIN_PASSWORD=cambiar-password-minimo-12-chars

# Operación / observabilidad
LOG_LEVEL=INFO
LOG_JSON=false
WEBHOOK_DEDUP_WINDOW_MINUTES=15

# CISA KEV (POST /api/vulnerabilities/sync-kev o arranque)
# KEV_SYNC_ON_STARTUP=false
# KEV_SYNC_LIMIT=
# CISA_KEV_URL=https://www.cisa.gov/sites/default/files/feeds/known_exploited_vulnerabilities.json

# --- Fase 2: Threat Intel (opcional) ---
# Sin claves = enriquecimiento simulado automatico
# Cuotas tipicas (revisar plan vigente del proveedor):
#   AbuseIPDB free: ~1.000 checks/dia
#   VirusTotal free: ~500 requests/dia (4 req/min)
ABUSEIPDB_API_KEY=
VIRUSTOTAL_API_KEY=

# --- Fase 3: Playbooks / respuesta automatizada ---
# Sin credenciales suficientes = modo simulado.
# mode=live en /api/integrations/status solo si la integración es ejecutable vía HTTP.
EDR_TYPE=                    # defender | crowdstrike
EDR_API_TOKEN=
EDR_API_URL=                 # Defender: https://api.securitycenter.microsoft.com/api
                             # Falcon: https://api.crowdstrike.com

FIREWALL_TYPE=                 # palo_alto | pfsense | generic
FIREWALL_API_URL=
FIREWALL_API_KEY=
FIREWALL_TLS_VERIFY=true

AZURE_AD_TENANT_ID=
AZURE_AD_CLIENT_ID=
AZURE_AD_CLIENT_SECRET=
# Alternativa a client credentials:
# AZURE_AD_ACCESS_TOKEN=

# Preferido para block_ip: callback SOAR/Ansible/n8n (HTTP real)
PLAYBOOK_CALLBACK_URL=

# JWT refresh (días)
JWT_REFRESH_TOKEN_EXPIRES=30

# LDAP (opcional)
# LDAP_ENABLED=false
# LDAP_SERVER=ldap://ldap.empresa.local
# LDAP_BASE_DN=ou=people,dc=empresa,dc=local
# LDAP_USER_DN_TEMPLATE=uid={username},{base_dn}
# LDAP_DEFAULT_ROLE=analyst

# P4 — 4-eyes, cookies, OIDC
PLAYBOOK_FOUR_EYES=true
# AUTH_COOKIE_MODE=false
# JWT_COOKIE_SECURE=false
# OIDC_ENABLED=false
# OIDC_ISSUER=https://login.microsoftonline.com/<tenant>/v2.0
# OIDC_CLIENT_ID=
# OIDC_CLIENT_SECRET=
# OIDC_REDIRECT_URI=http://localhost:5000/api/auth/oidc/callback
# OIDC_FRONTEND_REDIRECT=http://localhost:5173
# OIDC_ADMIN_GROUP=
